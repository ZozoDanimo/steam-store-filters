{
	"compilerOptions": {
		"target": "ES2020",
		"module": "ESNext",
		"moduleResolution": "node",
		"jsx": "react",
		"strict": false,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"allowSyntheticDefaultImports": true,
		"outDir": "./dist",
		"baseUrl": ".",
		"paths": {
			"@/*": ["./frontend/*"]
		}
	},
	"include": ["frontend/**/*", "types/**/*"],
	"exclude": ["node_modules", "dist"]
}
